{
  "manifest_version": 3,
  "name": "Social Auto Uploader",
  "version": "1.0",
  "description": "Auto upload generated videos to TikTok (with future support for YouTube, FB, IG).",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "downloads",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:*/*",
    "http://localhost:*/*",
    "https://www.tiktok.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Upload Video"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.tiktok.com/*"],
      "js": ["content_scripts/tiktok.js"],
      "run_at": "document_idle"
    }
  ]
}
